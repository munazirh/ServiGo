# Server Configuration
PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/servigo

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3000

# SMS Webhook URL (optional - leave empty for mock SMS)
# Example: https://sms-provider.com/api/send
SMS_WEBHOOK_URL=

# Email Configuration (SMTP)
# For Gmail: Use App Password (not regular password)
# Enable 2FA and generate App Password at: https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Alternative Email Providers:
# SendGrid: smtp.sendgrid.net, port 587
# Mailgun: smtp.mailgun.org, port 587
# Outlook: smtp.office365.com, port 587
